# active (this session) + an explicit ## NO-FORK escape after the marker → plan allowed
mkdir -p "$VIBEZOMBIE_DIR/sessions/sess-A"
printf 'L2\n' > "$VIBEZOMBIE_DIR/sessions/sess-A/active"
printf '# vibezombie decision log\n\n<!-- vz-session 2026-06-06T10:00:00Z -->\n## NO-FORK: docs-only plan, no architecture decision\n' > "$VIBEZOMBIE_DIR/log.md"
