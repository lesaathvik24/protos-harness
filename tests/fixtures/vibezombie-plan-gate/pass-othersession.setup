# vibezombie active (no fork) in sess-A; the plan is finalized in sess-B, which never
# invoked the skill → plan-gate must not fire (issue #1).
mkdir -p "$VIBEZOMBIE_DIR/sessions/sess-A"
printf 'L2 hard\n' > "$VIBEZOMBIE_DIR/sessions/sess-A/active"
printf '# vibezombie decision log\n\n<!-- vz-session 2026-06-06T11:00:00Z -->\n' > "$VIBEZOMBIE_DIR/log.md"
